[t:template,n:2W_dsx_gobbot_minigun_base]  // = 2W_dsx_gobbot_minigun
//balanced to Level 18
{
	category_name = "2W_evil_d";
	doc = "2W_dsx_gobbot_minigun";
	specializes = 2W_dsx_base_gobbot;
	[actor]
	{
		[skills]
		{
			strength 		=  41.2,0;
			intelligence 	=  11.8, 0;
			dexterity 		=  22, 0;
            ranged			=  63,0;
		}
	}
	[aspect]
	{
		experience_value = 62192;
		life 			= 965.6;
        	max_life 		= 965.6;
        	mana 			= 38.1;
        	max_mana 		= 38.1;
        	[textures]	
        	{ 
        		0 = b_c_edm_px_2; 
        	}
	}
	[attack]
	{
		attack_range = 0.5;
		damage_max = 185.5;
		damage_min = 132.2;
	}
	[common]
	{
		screen_name="Gobbot Sleeper";
	}

	[defend] { defense=357.7; }

	[inventory]
	{
		selected_active_location = IL_ACTIVE_RANGED_WEAPON;
	[pcontent]  //GUN
		{
			[oneof*]
			{
				ES_WEAPON_HAND = dsx_minigun_dragon;
			}
		}
	}
}
[t:template,n:2W_dsx_gobbot_minigun_fixed]
{
	specializes = 2W_dsx_gobbot_minigun_base;

	[physics]
	{
		[break_particulate]
		{
			frag_glb_dsx_gobbot_01 = 1;
			frag_glb_dsx_gobbot_02 = 2;
			frag_glb_dsx_gobbot_03 = 3;
			frag_glb_dsx_gobbot_04 = 2;
			frag_glb_dsx_gobbot_05 = 1;
			frag_glb_dsx_gobbot_06 = 3;
			frag_glb_dsx_gobbot_07 = 1;
		}
	}
}

