// The first Crystal Guardian you encounter.
[t:template,n:2W_dsx_shard_teal_base]  // = 2W_dsx_shard_teal
{
	category_name = "2W_evil_d";
	doc = "2W_dsx_shard_teal";
	specializes = 2W_dsx_shard_base;
	[aspect]
	{
		scale_base = 0.6;
		[textures] { 0 = b_c_edm_shard-01-static; }
		experience_value = 71214;
		life 			= 1799.5;
		max_life 		= 1799.5;
		mana			= 82.8;
		max_mana 		= 82.8;
	}
	[attack]
	{
		attack_range = 0.5;
		damage_max = 379.5;
		damage_min = 303;
		damage_bonus_min_cmagic = 162;
		damage_bonus_max_cmagic = 223;
	}
	[common]
	{
		[template_triggers]
		{
			[*]
			{
				condition* = receive_world_message("WE_ENTERED_WORLD");
				single_shot = true;
				no_trig_bits = true;
				action* = call_sfx_script("unique_ray_purple");
			}
		}
	}
	[defend] { defense=1010.2; }
	[inventory]
	{
		selected_active_location = il_active_primary_spell;
		[other] { il_active_primary_spell=dsx_spell_shard_zap_teal; }
	}
}
[t:template,n:2W_dsx_shard_teal_fixed]
{
	specializes = 2W_dsx_shard_teal_base;

	[physics]
	{
		[break_particulate]
		{
			frag_glb_dsx_shard_teal_01 = 1;
			frag_glb_dsx_shard_teal_02 = 1;
			frag_glb_dsx_shard_teal_03 = 2;
			frag_glb_dsx_shard_teal_04 = 3;
			frag_glb_dsx_shard_teal_05 = 3;
		}
	}
}

