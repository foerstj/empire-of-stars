[t:template,n:3W_dsx_gobbot_minigun_base]  // = 3W_dsx_gobbot_minigun
//balanced to Level 18
{
	category_name = "3W_evil_d";
	doc = "3W_dsx_gobbot_minigun";
	specializes = 3W_dsx_base_gobbot;
	[actor]
	{
		[skills]
		{
			strength 		=  55,0;
			intelligence 	=  13.7, 0;
			dexterity 		=  27.9, 0;
            ranged			=  91,0;
		}
	}
	[aspect]
	{
		experience_value = 1651676;
		life 			= 1363.2;
        	max_life 		= 1363.2;
        	mana 			= 53.8;
        	max_mana 		= 53.8;
        	[textures]	
        	{ 
        		0 = b_c_edm_px_2; 
        	}
	}
	[attack]
	{
		attack_range = 0.5;
		damage_max = 261.9;
		damage_min = 186.6;
	}
	[common]
	{
		screen_name="Gobbot Sleeper";
	}

	[defend] { defense=505; }

	[inventory]
	{
		selected_active_location = IL_ACTIVE_RANGED_WEAPON;
	[pcontent]  //GUN
		{
			[oneof*]
			{
				ES_WEAPON_HAND = dsx_minigun_dragon;
			}
		}
	}
}
[t:template,n:3W_dsx_gobbot_minigun_fixed]
{
	specializes = 3W_dsx_gobbot_minigun_base;

	[physics]
	{
		[break_particulate]
		{
			frag_glb_dsx_gobbot_01 = 1;
			frag_glb_dsx_gobbot_02 = 2;
			frag_glb_dsx_gobbot_03 = 3;
			frag_glb_dsx_gobbot_04 = 2;
			frag_glb_dsx_gobbot_05 = 1;
			frag_glb_dsx_gobbot_06 = 3;
			frag_glb_dsx_gobbot_07 = 1;
		}
	}
}

