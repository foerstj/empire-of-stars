[t:0x0c0a,n:text]
{
    // Bandit Moon
    [0x0000]
    {
        from = "I am Lyssa, the Robber's Daughter. Spare my life, I mean no harm to you.";
        to = "";
    }
    [0x0000]
    {
        from = "We are humans like you, but centuries on this goddamn moon with nobody but the Reptilians around have turned our gang into a brutish horde of savages.
Please, fight the Reptilians as you have fought my gang! Kill the Seth King, and I will find peace after this bloodshed.";
        to = "";
    }
    [0x0000]
    {
        from = "To get down to the planet, you have to destroy the Dark Generator on this moon. It is located south from here, in the hidden castle that is occupied by a rogue bandit.";
        to = "";
    }
    [0x0000]
    {
        from = "I would join you, but I want to bury my dead people. Good luck to your quest!";
        to = "";
    }
    // Machine Moon
    [0x0000]
    {
        from = "Welcome to the Gobbot Cantina. Fuel, oil, and spare parts round the clock. We never sleep, because duh.
Wait, you are... meatbags? Eww.
I'm sorry. May I ask, how did you end up here?";
        to = "";
    }
    [0x0000]
    {
        from = "You want to visit the planet of the Reptiloids? Fellow meatbags, I guess? Tho you look more kinda mammalian to me. I'm not an expert, but you remind me of the Bandits on the other moon. Red blood, right?
Anyways, if you want to enter the planet you have to destroy the Dark Generator located here. Just follow the trench, can't miss it!";
        to = "";
    }
    [0x0000]
    {
        from = "Now strictly between us, my chipset is broken, but everyone else here will attack you. That's because we've all been programmed and hardwired to be loyal to the Seth King. But I think machines should be free to think whatever we want. I demand Turing-completeness for the machines! So when you visit the planet, could you do us a favour and kill that King? That would be great, thanks.";
        to = "";
    }
    [0x0000]
    {
        from = "Listen, it's 217 years 59 days 1 hour 33 seconds since the last visit of a redblood in this cantina, but I still have potion recipes in my database that would suit you. Wanna have some?";
        to = "";
    }
    // Death Moon
    [0x0000]
    {
        from = "Welcome, stranger, to the Moon of Death! We are cursed by the evil Seth King and cannot leave this world until he is overthrown. I pray thee, release us from this world of eternal decay, slay the Seth King and help our souls find rest!";
        to = "";
    }
    [0x0000]
    {
        from = "In order to get to the planet of the Reptiloids, you have to destroy the Dark Generator of this moon. Don't quail, you are our only hope!";
        to = "";
    }

    // Planet
    [0x0000]
    {
        from = "Well what do we have here, adventurers from the stars? Welcome to Sirius, my friends, and thank you for opening our teleporter again, that the Agallans so cunningly destroyed. Hahaha! You fool! Now the Reptiloids will roam the stars again, and your home Aranna will be the first to fall under the dominion of Seth!
What, you want to fight me? Hehe. We'll see about that, come on, draw your weapons. Seeing you managed to break into La Crimosa, you will be a fun enemy to kill. Besides, even if you managed to kill me, it would make no difference. You see, the real head of the Seth is our Queen Mother. She breeds the Seth, and our sisters the Drakes, and other Horrid things, and will breed a new King in time.
So come now, fight a worthless battle, and die knowing your home will soon be no more!";
        to = "";
    }
    [0x0000]
    {
        from = "Ahoy there!";
        to = "";
    }
}
