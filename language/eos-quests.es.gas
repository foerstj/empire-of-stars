    [0x0000]
    {
        from = "Find Aunt Luna";
        to = "Encuentra a la Tía Luna";
    }
    [0x0000]
    {
        from = "After having received a letter informing you that your strange but beloved Aunt Luna has disappeared, you took the long journey to the place she was last seen. You hope to find her alive and well.";
        to = "Tras recibir una carta informándote de la desaparición de tu peculiar pero querida Tía Luna, emprendiste el largo viaje hasta el lugar donde fue vista por última vez. Esperas encontrarla sana y salva.";
    }
    [0x0000]
    {
        from = "You found Aunt Luna alive and well.";
        to = "Encontraste a la Tía Luna sana y salva.";
    }
    [0x0000]
    {
        from = "Find Way Home";
        to = "Encuentra el Camino a Casa";
    }
    [0x0000]
    {
        from = "Oh no, you went into the Interstellar Hub without the right starstone to get back home! You need to find an Aranna Starstone. Maybe Aunt Luna can help you... But she's on Betelgeuse.";
        to = "¡Oh no! ¡Entraste al Centro Interestelar sin la piedra estelar adecuada para volver a casa! Necesitas encontrar una Piedra Estelar de Aranna. Quizás la Tía Luna pueda ayudarte... Pero está en Betelgeuse.";
    }
    [0x0000]
    {
        from = "Oh no, you went into the Interstellar Hub without the right starstone to get back home! You need to find an Aranna Starstone.";
        to = "¡Oh no! ¡Entraste al Centro Interestelar sin la piedra estelar adecuada para volver a casa! Necesitas encontrar una Piedra Estelar de Aranna.";
    }
    [0x0000]
    {
        from = "Find an Aranna Starstone on Sirius to get back home.";
        to = "Encuentra una Piedra Estelar de Aranna en Sirius para volver a casa.";
    }
    [0x0000]
    {
        from = "After an odyssey among the stars, you are finally able to return home to Aranna.";
        to = "Tras una odisea entre las estrellas, por fin puedes regresar a casa, a Aranna.";
    }
    [0x0000]
    {
        from = "The Chapel";
        to = "La Capilla";
    }
    [0x0000]
    {
        from = "Clear the Krug from the Chapel's basement, and gather supplies for the way to the Crypt.";
        to = "Elimina a los Krug del sótano de la capilla y reúne suministros para llegar a la cripta.";
    }
    [0x0000]
    {
        from = "The Crypt";
        to = "La Cripta";
    }
    [0x0000]
    {
        from = "Look for Starstones in the Crypt.";
        to = "Busca Piedras Estelares en la Cripta.";
    }
    [0x0000]
    {
        from = "The Elder of the Lake";
        to = "El Anciano del Lago";
    }
    [0x0000]
    {
        from = "See the Elder of the Lake about starstones. He lives in the village of Wishy-Washy.";
        to = "Consulta al Anciano del Lago sobre las piedras estelares. Él vive en el pueblo de Wishy-Washy.";
    }
    [0x0000]
    {
        from = "Speak again with Annek back in Palim Palim.";
        to = "Vuelve a hablar con Annek en Palim Palim.";
    }
    [0x0000]
    {
        from = "Book Return";
        to = "Devolución de Libros";
    }
    [0x0000]
    {
        from = "Find the first two volumes in the Thawhorn's Way trilogy.";
        to = "Encuentra los dos primeros volúmenes de la Trilogía del Camino de Thawhorn.";
    }
    [0x0000]
    {
        from = "The Fireheart Caverns";
        to = "Las Cavernas Corazón de Fuego";
    }
    [0x0000]
    {
        from = "Look for Starstones in the Fireheart Caverns.";
