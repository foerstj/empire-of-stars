        to = "Orionis";
    }
    [0x0000]
    {
        from = "Clear Orionis of the savage Droog - speak with Gucup Cakix near the teleporter.";
        to = "Libera Orionis de los Droog salvajes: habla con Gucup Cakix cerca del teletransportador.";
    }
    [0x0000]
    {
        from = "Clear Orionis of the savage Droog - south, east, and south-west from the teleporter.";
        to = "Libera Orionis de los Droog salvajes: al sur, este y suroeste desde el teletransportador.";
    }
    [0x0000]
    {
        from = "Speak again with Gucup Cakix near the teleporter.";
        to = "Habla de nuevo con Gucup Cakix cerca del teletransportador.";
    }
    [0x0000]
    {
        from = "Orionis is safe.";
        to = "Orionis es seguro.";
    }
