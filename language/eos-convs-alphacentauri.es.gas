[t:0x0c0a,n:text]
{
    [0x0000]
    {
        from = "Did you really just come from the stars? How incredible!
As the mayor of this village I want to welcome you to Eddiloo... and Alpha Centauri, I guess.";
        to = "";
    }
    [0x0000]
    {
        from = "You are looking for an ancient artifact with a hammer or fish symbol on it? Not sure I can help you...
Maybe a good place to go looking for ancient artifacts would be the Crypt... yes. It's right in the forest. Be careful though - it's a New Moon, and the woods are full of Krug, and in the Crypt, the dead might be... awake.";
        to = "";
    }
    [0x0000]
    {
        from = "Apart from ancient artifacts, is there anything I can help you with?";
        to = "";
    }
    [0x0000]
    {
        from = "Hello stranger, welcome to Alpha Centauri.
Do you happen to be interested in a packmule? Will come in handy when you go out and find more treasure than you can carry...";
        to = "";
    }
    [0x0000]
    {
        from = "Hello stranger, welcome to Alpha Centauri.";
        to = "";
    }
    [0x0000]
    {
        from = "I hope Eberhardt is doing well?";
        to = "";
    }
    [0x0000]
    {
        from = "Is it true you came from the stars? Oh please take me with you! I have a few debts to pay but then I'm all yours. Take me away from here, will you? This is the middle of nowhere. There's not a single tavern within a week's march! I want to see the world and have adventures...";
        to = "";
    }
    [0x0000]
    {
        from = "Take me away from here, will you? This is the middle of nowhere. There's not a single tavern within a week's march! I want to see the world and have adventures...";
        to = "";
    }
    [0x0000]
    {
        from = "I have a few debts to pay but then I'm all yours.";
        to = "";
    }
    [0x0000]
    {
        from = "Is it true you came from the stars? Oh how I envy you! This is the middle of nowhere. There's not a single tavern within a week's march! I would love to see the world and have adventures... but I have obligations here. Farewell!";
        to = "";
    }
    [0x0000]
    {
        from = "Hello, welcome to Eddiloo.";
        to = "";
    }
    [0x0000]
    {
        from = "Welcome to Eddiloo!";
        to = "";
    }
    [0x0000]
    {
        from = "Oh I'm in trouble...
Oh hello there, stranger. Welcome to our little chapel...";
        to = "";
    }
    [0x0000]
    {
        from = "I am the sacristan here. But I don't know for how long still...
I forgot again to lock the door to the cellar, and now it's full of Krug! It would be my job to chase them off but... Truth is I'm a fat old man and I got it in the shoulders, and... I'm afraid of them. Say, could you help me?";
        to = "";
    }
    [0x0000]
    {
        from = "Whatever supplies you still find down there, take them, they're yours, just please help me get rid of the Krug...";
        to = "";
    }
    [0x0000]
    {
        from = "My thanks for clearing out the Krug. If they're coming so close to our village, I don't doubt you'll battle many more on your way to the Crypt. Watch out for yourself and don't worry about me.";
        to = "";
    }
}
